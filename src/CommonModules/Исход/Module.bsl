// =========================================================================================
// Общий модуль: Исход (Монада Either / Паттерн Result)
// Назначение: Единый стандарт обработки и возврата результатов выполнения бизнес-логики.
// =========================================================================================
#Область ПрограммныйИнтерфейс

// Возвращает текущую версию библиотеки Исход.
// Используется для проверки совместимости в других модулях.
//
// Возвращаемое значение:
//  Строка - Версия в формате Семантического Версионирования (SemVer).
Функция Версия() Экспорт
	Возврат "0.1.0"; 
КонецФункции

#Область Конструкторы

// Создает успешный результат выполнения.
//
// Параметры:
//  Значение - Произвольный - Значение, которое нужно обернуть в успешный Исход.
//
// Возвращаемое значение:
//  Структура - Обертка успешного результата:
//   * Успех    - Булево - Всегда Истина.
//   * Значение - Произвольный - Переданное значение.
//   * Ошибка   - Неопределено - Ошибок нет.
Функция Ок(Знач Значение) Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успех", Истина);
	Результат.Вставить("Значение", Значение);
	Результат.Вставить("Ошибка", Неопределено);
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

// Создает результат с ошибкой.
//
// Параметры:
//  ТекстОшибки          - Строка - Человекочитаемое описание ошибки.
//  ДополнительныеДанные - Произвольный - Детали ошибки (код, структура с логами, ИнформацияОбОшибке и т.д.).
//
// Возвращаемое значение:
//  Структура - Обертка результата с ошибкой:
//   * Успех    - Булево - Всегда Ложь.
//   * Значение - Неопределено - Значение отсутствует.
//   * Ошибка   - Структура - Детали ошибки (Текст, Данные).
Функция Ошибка(Знач ТекстОшибки, Знач ДополнительныеДанные = Неопределено) Экспорт
	
	ДанныеОшибки = Новый Структура;
	ДанныеОшибки.Вставить("Текст", ТекстОшибки);
	ДанныеОшибки.Вставить("Данные", ДополнительныеДанные);

	Результат = Новый Структура;
	Результат.Вставить("Успех", Ложь);
	Результат.Вставить("Значение", Неопределено);
	Результат.Вставить("Ошибка", ДанныеОшибки);
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ПроверкаСостояния

// Проверяет, является ли результат успешным.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход.
//
// Возвращаемое значение:
//  Булево - Истина, если результат успешен, иначе Ложь.
Функция ЭтоУспех(Знач ТекущийРезультат) Экспорт
	Возврат ТекущийРезультат.Успех;
КонецФункции

// Проверяет, содержит ли результат ошибку.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход.
//
// Возвращаемое значение:
//  Булево - Истина, если результат содержит ошибку, иначе Ложь.
Функция ЭтоОшибка(Знач ТекущийРезультат) Экспорт
	Возврат Не ТекущийРезультат.Успех;
КонецФункции

#КонецОбласти

#Область ПолучениеДанных

// Извлекает базовый текст ошибки для показа пользователю.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход.
//
// Возвращаемое значение:
//  Строка - Текст ошибки или пустая строка, если это успех.
Функция ТекстОшибки(Знач ТекущийРезультат) Экспорт
	
	Если ЭтоУспех(ТекущийРезультат) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ТекущийРезультат.Ошибка.Текст;
	
КонецФункции

// Формирует полный технический лог ошибки, включая вложенные данные.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход.
//
// Возвращаемое значение:
//  Строка - Детальный лог (Текст + Технические подробности).
Функция ПодробныйТекстОшибки(Знач ТекущийРезультат) Экспорт
	
	Если ЭтоУспех(ТекущийРезультат) Тогда
		Возврат "";
	КонецЕсли;

	ДанныеОшибки = ТекущийРезультат.Ошибка;
	ДопДанные = ДанныеОшибки.Данные;

	Если ДопДанные = Неопределено Тогда
		Возврат ДанныеОшибки.Текст;
	КонецЕсли;

	ЧастиЛога = Новый Массив;
	ЧастиЛога.Добавить(ДанныеОшибки.Текст);
	ЧастиЛога.Добавить("--- Детали ---");

	ТипДопДанных = ТипЗнч(ДопДанные);
	Если ТипДопДанных = Тип("ИнформацияОбОшибке") Тогда
		ЧастиЛога.Добавить(ОбработкаОшибок.ПодробноеПредставлениеОшибки(ДопДанные));
	ИначеЕсли ТипДопДанных = Тип("Строка") Тогда
		ЧастиЛога.Добавить(ДопДанные);
	Иначе
		#Если НаСервере Или ТолстыйКлиентОбычноеПриложение Или ТолстыйКлиентУправляемоеПриложение Или ВнешнееСоединение Тогда
		ЧастиЛога.Добавить(ЗначениеВСтрокуВнутр(ДопДанные));
		#Иначе
		ЧастиЛога.Добавить(Строка(ДопДанные));
		#КонецЕсли
	КонецЕсли;

	Возврат СтрСоединить(ЧастиЛога, Символы.ПС);
	
КонецФункции

// Безопасно извлекает значение или возвращает значение по умолчанию при ошибке.
//
// Параметры:
//  ТекущийРезультат    - Структура - Объект монады Исход.
//  ЗначениеПоУмолчанию - Произвольный - Значение, которое вернется в случае ошибки.
//
// Возвращаемое значение:
//  Произвольный - Значение из монады или значение по умолчанию.
Функция ИзвлечьИли(Знач ТекущийРезультат, Знач ЗначениеПоУмолчанию) Экспорт
	
	Если ЭтоУспех(ТекущийРезультат) Тогда
		Возврат ТекущийРезультат.Значение;
	КонецЕсли;
	
	Возврат ЗначениеПоУмолчанию;
	
КонецФункции

// Жестко извлекает значение. Если внутри ошибка — вызывает исключение платформы.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход.
//
// Возвращаемое значение:
//  Произвольный - Значение успешного результата.
Функция Извлечь(Знач ТекущийРезультат) Экспорт
	
	Если ЭтоУспех(ТекущийРезультат) Тогда
		Возврат ТекущийРезультат.Значение;
	КонецЕсли;
	
	ВызватьИсключение ПодробныйТекстОшибки(ТекущийРезультат);
	
КонецФункции

#КонецОбласти

#Область МонадическиеОперации

// Выбрасывает классическое исключение, если в результате ошибка.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход.
Процедура РазвернутьИлиВызватьИсключение(Знач ТекущийРезультат) Экспорт
	
	Если ЭтоОшибка(ТекущийРезультат) Тогда
		ВызватьИсключение ПодробныйТекстОшибки(ТекущийРезультат);
	КонецЕсли;
	
КонецПроцедуры

// Обогащает текст ошибки дополнительным контекстом (например: "Ошибка API: " + Текст).
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
//  ПрефиксТекста    - Строка - Текст, который будет добавлен перед исходным текстом ошибки.
//
// Возвращаемое значение:
//  Структура - Новый или исходный объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
Функция ОбернутьОшибку(Знач ТекущийРезультат, Знач ПрефиксТекста) Экспорт
	
	Если ЭтоУспех(ТекущийРезультат) Тогда
		Возврат ТекущийРезультат;
	КонецЕсли;
	
	НовыйТекст = ПрефиксТекста + ": " + ТекущийРезультат.Ошибка.Текст;
	
	//@skip-check constructor-function-return-section
	Возврат Ошибка(НовыйТекст, ТекущийРезультат.Ошибка.Данные);
	
КонецФункции

// Преобразует массив результатов Исход в единый Исход, содержащий массив значений.
// Если есть хоть одна ошибка, возвращает первую найденную ошибку.
//
// Параметры:
//  МассивРезультатов - Массив из Структура - Массив структур (объектов монады Исход).
//
// Возвращаемое значение:
//  Структура, Произвольный - Итоговый объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Массив из Произвольный, Произвольный - Массив извлеченных значений.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
Функция СобратьМассив(Знач МассивРезультатов) Экспорт
	
	ИтоговыеЗначения = Новый Массив;
	Для Каждого ТекущийРезультат Из МассивРезультатов Цикл
		Если ЭтоОшибка(ТекущийРезультат) Тогда
			Возврат ТекущийРезультат;
		КонецЕсли;
		ИтоговыеЗначения.Добавить(ТекущийРезультат.Значение);
	КонецЦикла;
	
	//@skip-check constructor-function-return-section
	Возврат Ок(ИтоговыеЗначения);
	
КонецФункции

#Если НаСервере Тогда

// Связывает цепочку вызовов функций, возвращающих Исход.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход.
//  ПолноеИмяМетода  - Строка - Имя серверной экспортной функции.
//  ДопПараметры     - Произвольный - Дополнительные параметры для передачи.
//
// Возвращаемое значение:
//  Структура - Новый объект монады Исход, возвращенный вызываемым методом.
Функция Связать(Знач ТекущийРезультат, Знач ПолноеИмяМетода, Знач ДопПараметры = Неопределено) Экспорт
	
	Если ЭтоОшибка(ТекущийРезультат) Тогда
		Возврат ТекущийРезультат;
	КонецЕсли;

	ТекущийБезопасныйРежим = БезопасныйРежим();
	УстановитьБезопасныйРежим(Истина);
	РезультатВызова = ВызватьМетодСПараметрами(ПолноеИмяМетода, ТекущийРезультат.Значение, ДопПараметры);
	УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
	
	Возврат РезультатВызова;
	
КонецФункции

// Безопасно связывает вызов функции, перехватывая платформенные исключения.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
//  ПолноеИмяМетода  - Строка - Имя серверной экспортной функции.
//  ДопПараметры     - Произвольный - Дополнительные параметры для передачи.
//
// Возвращаемое значение:
//  Структура - Новый объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
Функция ПопытатьсяСвязать(Знач ТекущийРезультат, Знач ПолноеИмяМетода, Знач ДопПараметры = Неопределено) Экспорт
	
	Если ЭтоОшибка(ТекущийРезультат) Тогда
		Возврат ТекущийРезультат;
	КонецЕсли;

	ТекущийБезопасныйРежим = БезопасныйРежим();
	УстановитьБезопасныйРежим(Истина);
	
	Попытка
		РезультатВызова = ВызватьМетодСПараметрами(ПолноеИмяМетода, ТекущийРезультат.Значение, ДопПараметры);
		УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
		
		Возврат РезультатВызова;
	Исключение
		УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
		Информация = ИнформацияОбОшибке();
		
		//@skip-check constructor-function-return-section
		Возврат Ошибка(ОбработкаОшибок.КраткоеПредставлениеОшибки(Информация), Информация);
	КонецПопытки;
	
КонецФункции

// Вызывает обычную функцию и автоматически заворачивает результат в Ок().
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
//  ПолноеИмяМетода  - Строка - Имя серверной экспортной функции.
//  ДопПараметры     - Произвольный - Дополнительные параметры для передачи.
//
// Возвращаемое значение:
//  Структура - Новый объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
Функция Отобразить(Знач ТекущийРезультат, Знач ПолноеИмяМетода, Знач ДопПараметры = Неопределено) Экспорт
	
	Если ЭтоОшибка(ТекущийРезультат) Тогда
		Возврат ТекущийРезультат;
	КонецЕсли;

	ТекущийБезопасныйРежим = БезопасныйРежим();
	УстановитьБезопасныйРежим(Истина);
	
	СыройРезультат = ВызватьМетодСПараметрами(ПолноеИмяМетода, ТекущийРезультат.Значение, ДопПараметры);
	
	УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
	
	Возврат Ок(СыройРезультат);
	
КонецФункции

// Работает как Отобразить, но перехватывает исключения 1С.
//
// Параметры:
//  ТекущийРезультат - Структура - Объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
//  ПолноеИмяМетода  - Строка - Имя серверной экспортной функции.
//  ДопПараметры     - Произвольный - Дополнительные параметры для передачи.
//
// Возвращаемое значение:
//  Структура - Новый объект монады Исход:
//   * Успех    - Булево - Состояние результата.
//   * Значение - Произвольный - Данные результата.
//   * Ошибка   - Структура, Неопределено - Детали ошибки.
Функция ПопытатьсяОтобразить(Знач ТекущийРезультат, Знач ПолноеИмяМетода, Знач ДопПараметры = Неопределено) Экспорт
	
	Если ЭтоОшибка(ТекущийРезультат) Тогда
		Возврат ТекущийРезультат;
	КонецЕсли;

	ТекущийБезопасныйРежим = БезопасныйРежим();
	УстановитьБезопасныйРежим(Истина);
	
	Попытка
		СыройРезультат = ВызватьМетодСПараметрами(ПолноеИмяМетода, ТекущийРезультат.Значение, ДопПараметры);
		УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
		
		Возврат Ок(СыройРезультат);
	Исключение
		УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
		Информация = ИнформацияОбОшибке();
		
		//@skip-check constructor-function-return-section
		Возврат Ошибка(ОбработкаОшибок.КраткоеПредставлениеОшибки(Информация), Информация);
	КонецПопытки;
КонецФункции

// Побочный эффект: вызывает ПРОЦЕДУРУ, только если результат успешен. Возвращает Исход без изменений.
//
// Параметры:
//  ТекущийРезультат   - Структура - Объект монады Исход.
//  ПолноеИмяПроцедуры - Строка - Имя серверной экспортной процедуры.
//  ДопПараметры       - Произвольный - Дополнительные параметры для передачи.
//
// Возвращаемое значение:
//  Структура - Исходный объект монады Исход.
Функция ПриУспехе(Знач ТекущийРезультат, Знач ПолноеИмяПроцедуры, Знач ДопПараметры = Неопределено) Экспорт
	
	Если ЭтоУспех(ТекущийРезультат) Тогда
		ТекущийБезопасныйРежим = БезопасныйРежим();
		УстановитьБезопасныйРежим(Истина);
		
		ВызватьПроцедуруСПараметрами(ПолноеИмяПроцедуры, ТекущийРезультат.Значение, ДопПараметры);
		
		УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
	КонецЕсли;
	
	Возврат ТекущийРезультат;
	
КонецФункции

// Побочный эффект: вызывает ПРОЦЕДУРУ, только если результат - ошибка. Возвращает Исход без изменений.
//
// Параметры:
//  ТекущийРезультат   - Структура - Объект монады Исход.
//  ПолноеИмяПроцедуры - Строка - Имя серверной экспортной процедуры.
//  ДопПараметры       - Произвольный - Дополнительные параметры для передачи.
//
// Возвращаемое значение:
//  Структура - Исходный объект монады Исход.
Функция ПриОшибке(Знач ТекущийРезультат, Знач ПолноеИмяПроцедуры, Знач ДопПараметры = Неопределено) Экспорт
	
	Если ЭтоОшибка(ТекущийРезультат) Тогда
		ТекущийБезопасныйРежим = БезопасныйРежим();
		УстановитьБезопасныйРежим(Истина);
		
		ВызватьПроцедуруСПараметрами(ПолноеИмяПроцедуры, ТекущийРезультат.Ошибка, ДопПараметры);
		
		УстановитьБезопасныйРежим(ТекущийБезопасныйРежим);
	КонецЕсли;
	
	Возврат ТекущийРезультат;
	
КонецФункции

#КонецЕсли

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Если НаСервере Тогда

// Выполняет динамический вызов ФУНКЦИИ (возвращающей значение).
Функция ВызватьМетодСПараметрами(Знач ПолноеИмяМетода, Знач ВходноеЗначение, Знач ДопПараметры)
	
	МассивПараметров = ПодготовитьМассивПараметров(ДопПараметры);
	ИменаАргументов = ПодготовитьИменаАргументов(МассивПараметров);

	ТекстВыражения = ПолноеИмяМетода + "(" + СтрСоединить(ИменаАргументов, ", ") + ")";
	
	//@skip-check server-execution-safe-mode
	Возврат Вычислить(ТекстВыражения);
	
КонецФункции

// Выполняет динамический вызов ПРОЦЕДУРЫ (не возвращающей значение).
Процедура ВызватьПроцедуруСПараметрами(Знач ПолноеИмяМетода, Знач ВходноеЗначение, Знач ДопПараметры)
	
	МассивПараметров = ПодготовитьМассивПараметров(ДопПараметры);
	ИменаАргументов = ПодготовитьИменаАргументов(МассивПараметров);

	ТекстВыражения = ПолноеИмяМетода + "(" + СтрСоединить(ИменаАргументов, ", ") + ");";
	
	//@skip-check server-execution-safe-mode
	Выполнить (ТекстВыражения);
	
КонецПроцедуры

// Нормализует дополнительные параметры в Массив.
Функция ПодготовитьМассивПараметров(Знач ДопПараметры)
	
	МассивПараметров = Новый Массив;
	Если ДопПараметры <> Неопределено Тогда
		Если ТипЗнч(ДопПараметры) = Тип("Массив") Тогда
			МассивПараметров = ДопПараметры;
		Иначе
			МассивПараметров.Добавить(ДопПараметры);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивПараметров;
	
КонецФункции

// Генерирует массив строк вида "МассивПараметров[0]" для Вычислить/Выполнить.
Функция ПодготовитьИменаАргументов(Знач МассивПараметров)
	
	ИменаАргументов = Новый Массив;
	ИменаАргументов.Добавить("ВходноеЗначение");

	Для Индекс = 0 По МассивПараметров.ВГраница() Цикл
		ИменаАргументов.Добавить("МассивПараметров[" + XMLСтрока(Индекс) + "]");
	КонецЦикла;
	
	Возврат ИменаАргументов;
	
КонецФункции

#КонецЕсли

#КонецОбласти